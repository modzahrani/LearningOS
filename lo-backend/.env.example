DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# Keep true in production. Set false only for local debugging if your network injects self-signed certs.
DB_SSL_VERIFY=true

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_OR_SERVICE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
# Local testing helper: skip Supabase Auth signup to avoid rate limits.
BYPASS_SUPABASE_AUTH=false

FRONTEND_URL=https://app.yourdomain.com
APP_ENV=production

# Comma-separated origins for CORS
ALLOWED_ORIGINS=https://app.yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Auth cookie settings
ACCESS_TOKEN_COOKIE=access_token
COOKIE_SECURE=true
# Use `none` when frontend/backend are on different domains.
COOKIE_SAMESITE=none
# COOKIE_DOMAIN=.yourdomain.com

# Optional server/JWKS tuning
HOST=0.0.0.0
PORT=8000
JWKS_CACHE_TTL_SECONDS=300
JWKS_REQUEST_TIMEOUT_SECONDS=3
